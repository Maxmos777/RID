# =============================================================================
# RID Platform — Variáveis de Ambiente
# =============================================================================
# Instruções:
#   cp .env.example .env
#   Preenche os valores marcados como REQUIRED antes de iniciar.
#   Variáveis marcadas como OPTIONAL têm valor padrão funcional para dev.
#
# ATENÇÃO: Nunca commitar o ficheiro .env real no Git.
# =============================================================================


# -----------------------------------------------------------------------------
# Django — configuração central
# -----------------------------------------------------------------------------

# [REQUIRED] Chave secreta do Django. Gera com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=dev-insecure-change-in-production-please-do-not-use-this

# [OPTIONAL] Activa o modo de debug. NUNCA colocar True em produção.
# Valores aceites: True | False
DJANGO_DEBUG=True

# [REQUIRED] Hosts permitidos (vírgulas, sem espaços desnecessários). Docker Desktop:
# incluir host.docker.internal se abrires pelo nome. testserver = pytest Client.
# Em produção: DJANGO_ALLOWED_HOSTS=meudominio.com,api.meudominio.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal,testserver

# [OPTIONAL] Sem Domain para o hostname → usar schema public (django-tenants). NUNCA em prod
# com DEBUG=False a menos que saibas o risco. O docker-compose define true para dev.
# DJANGO_SHOW_PUBLIC_IF_NO_TENANT=true

# [OPTIONAL] Proxy reverso com X-Forwarded-Host
# DJANGO_USE_X_FORWARDED_HOST=true

# [OPTIONAL] CSRF para origens extra (vírgulas), ex.: https://app.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

# [OPTIONAL] Chave WSGI para resolver tenant por UUID (cabeçalho HTTP X-Tenant-Id).
# Valor por defeito: HTTP_X_TENANT_ID. Definir vazio para desactivar e usar só hostname.
# TENANT_RESOLUTION_HEADER=HTTP_X_TENANT_ID


# -----------------------------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------------------------

# [REQUIRED] URL de ligação completa (alternativa a configurar os campos individuais abaixo).
# Formato: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Em docker-compose, o HOST deve ser "db" (nome do serviço).
DATABASE_URL=postgres://rid:rid@localhost:5433/rid

# [REQUIRED] Host do servidor PostgreSQL.
DATABASE_HOST=localhost

# [OPTIONAL] Porta do servidor PostgreSQL. Padrão: 5432.
DATABASE_PORT=5433            # Docker maps host:5433 -> container:5432

# [REQUIRED] Nome da base de dados.
DATABASE_NAME=rid

# [REQUIRED] Utilizador da base de dados.
DATABASE_USER=rid

# [REQUIRED] Palavra-passe do utilizador da base de dados.
DATABASE_PASSWORD=rid


# -----------------------------------------------------------------------------
# Redis — cache e sessões
# -----------------------------------------------------------------------------

# [REQUIRED] URL de ligação ao Redis.
# Em docker-compose, usar: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# Multi-tenancy — Ring Standards (obrigatório declarar explicitamente)
# -----------------------------------------------------------------------------

# [REQUIRED] Activa ou desactiva o isolamento multi-tenant.
# false = schema público partilhado (dev local); true = schema por tenant (produção).
MULTI_TENANT_ENABLED=false


# -----------------------------------------------------------------------------
# Langflow — plataforma de fluxos LLM (perfil docker-compose: langflow)
# -----------------------------------------------------------------------------

# [OPTIONAL] URL base do servidor Langflow. Necessário quando MULTI_TENANT_ENABLED=true.
LANGFLOW_BASE_URL=http://langflow:7860

# [OPTIONAL] API Key do superuser Langflow — gerar em Settings → API Keys no painel.
# Necessária para provisionar workspaces por tenant (Customer.langflow_workspace_id).
# Se ausente, langflow_workspace_id fica null — tenant é criado na mesma (graceful degradation).
LANGFLOW_SUPERUSER_API_KEY=

# [OPTIONAL] Utilizador superadmin do Langflow.
LANGFLOW_SUPERUSER=admin

# [OPTIONAL] Palavra-passe do superadmin do Langflow.
LANGFLOW_SUPERUSER_PASSWORD=adminpassword

# O backend cria um utilizador de serviço por tenant (POST /api/v1/users/). A imagem
# Langflow deve permitir registo com utilizador activo (comportamento por defeito em dev).
#
# Docker Compose: Langflow usa a mesma database PostgreSQL que o Django (`rid`), com role
# e schema dedicados (`langflow`). Variável no compose: LANGFLOW_DB_PASSWORD.


# -----------------------------------------------------------------------------
# Stripe — pagamentos
# -----------------------------------------------------------------------------

# [REQUIRED em produção] Chave secreta da API Stripe.
# Em dev, usar chave de teste: sk_test_...
# Documentação: https://stripe.com/docs/keys
STRIPE_SECRET_KEY=sk_test_placeholder

# [REQUIRED em produção] Segredo do webhook Stripe para validar eventos recebidos.
# Obtém em: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_placeholder


# =============================================================================
# Traefik Auth Gate — rid-langflow-single-entry
# =============================================================================

# Origens CORS permitidas pelo Langflow.
# Deve corresponder ao domínio da plataforma RID acessado pelo browser (via Traefik).
# Em produção: https://app.rid.example.com
# Em desenvolvimento local: http://localhost:5173 (ou porta do Vite)
LANGFLOW_CORS_ORIGINS=https://app.rid.example.com
